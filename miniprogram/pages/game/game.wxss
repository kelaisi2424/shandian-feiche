.game-page {
  position: fixed;
  inset: 0;
  overflow: hidden;
  background: #9be7ff;
}

.game-canvas {
  position: absolute;
  inset: 0;
  width: 100vw;
  height: 100vh;
}

.hud {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  padding: calc(env(safe-area-inset-top) + 18rpx) 22rpx 0;
  pointer-events: none;
}

.hud-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.hud-stack {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.hud-stack.right {
  align-items: flex-end;
}

.hud-pill {
  min-width: 118rpx;
  height: 54rpx;
  padding: 0 18rpx;
  border-radius: 27rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 26rpx;
  font-weight: 800;
  text-shadow: 0 2rpx 4rpx rgba(40, 38, 72, .35);
  box-shadow: 0 6rpx 0 rgba(32, 42, 90, .24), inset 0 3rpx 0 rgba(255, 255, 255, .32);
}

.score {
  background: linear-gradient(180deg, #ffd95e, #ff9b4a);
}

.coins {
  background: linear-gradient(180deg, #68d391, #2fba74);
}

.stage {
  background: linear-gradient(180deg, #8fc9ff, #4f8df2);
}

.timer {
  background: linear-gradient(180deg, #54d6c2, #2da98e);
}

.timer.warn {
  background: linear-gradient(180deg, #ff8a80, #f45151);
}

.pause-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-top: 2rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: 900;
  background: rgba(50, 54, 108, .62);
  box-shadow: 0 6rpx 0 rgba(22, 24, 68, .28), inset 0 3rpx 0 rgba(255, 255, 255, .24);
  pointer-events: auto;
}

.mini-goal {
  position: relative;
  height: 44rpx;
  margin: 16rpx auto 0;
  width: 58vw;
  max-width: 440rpx;
  border-radius: 22rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, .45);
  border: 3rpx solid rgba(255, 255, 255, .58);
  box-shadow: 0 6rpx 16rpx rgba(44, 60, 120, .14);
}

.mini-goal-bar {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  border-radius: 22rpx;
  background: linear-gradient(90deg, #ffbf54, #ffe66d, #8de36f);
}

.mini-goal text {
  position: relative;
  z-index: 1;
  display: flex;
  width: 100%;
  height: 100%;
  align-items: center;
  justify-content: center;
  color: #354060;
  font-size: 22rpx;
  font-weight: 900;
}

.control-pad {
  position: absolute;
  left: 0;
  right: 0;
  bottom: calc(env(safe-area-inset-bottom) + 26rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 44rpx;
}

.round-control,
.jump-control {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-weight: 900;
  text-shadow: 0 3rpx 5rpx rgba(38, 39, 86, .35);
  box-shadow: 0 10rpx 0 rgba(64, 79, 156, .32), inset 0 4rpx 0 rgba(255, 255, 255, .34);
}

.round-control {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #75c8ff, #4d88ee);
  font-size: 58rpx;
}

.jump-control {
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #ffcb5b, #ff6f91);
  font-size: 34rpx;
}

.screen {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 36rpx;
}

.title-screen {
  background: linear-gradient(160deg, #77d9ff 0%, #b8f0d2 46%, #ffe493 100%);
}

.float-stars {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
}

.float-stars text {
  position: absolute;
  bottom: -80rpx;
  font-size: 44rpx;
  opacity: .6;
  animation-name: floatUp;
  animation-timing-function: linear;
  animation-iteration-count: infinite;
}

@keyframes floatUp {
  0% {
    transform: translateY(0) rotate(0deg);
    opacity: 0;
  }
  12% {
    opacity: .7;
  }
  100% {
    transform: translateY(-112vh) rotate(320deg);
    opacity: 0;
  }
}

.brand {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-top: 24rpx;
}

.eyebrow {
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  color: #376061;
  font-size: 24rpx;
  font-weight: 800;
  background: rgba(255, 255, 255, .55);
}

.title {
  color: #fff9be;
  font-size: 76rpx;
  font-weight: 900;
  line-height: 1;
  text-shadow: 0 6rpx 0 #f08a54, 0 13rpx 24rpx rgba(68, 68, 118, .24);
}

.subtitle {
  color: #37515f;
  font-size: 26rpx;
  font-weight: 800;
}

.pet-row {
  position: relative;
  width: 100%;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
  margin-top: 42rpx;
}

.pet-card {
  height: 150rpx;
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  background: rgba(255, 255, 255, .55);
  border: 4rpx solid rgba(255, 255, 255, .76);
  box-shadow: 0 8rpx 18rpx rgba(62, 92, 120, .15);
}

.pet-card.active {
  background: linear-gradient(180deg, #fff4a6, #ffbf69);
  transform: translateY(-8rpx);
  box-shadow: 0 14rpx 22rpx rgba(246, 150, 72, .26);
}

.pet-emoji {
  font-size: 54rpx;
}

.pet-name {
  color: #365062;
  font-size: 22rpx;
  font-weight: 900;
}

.health-card {
  position: relative;
  width: 100%;
  margin-top: 28rpx;
  padding: 18rpx 22rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, .55);
  border: 3rpx solid rgba(255, 255, 255, .68);
}

.health-card view {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
  color: #3c5465;
  font-size: 24rpx;
  font-weight: 800;
}

.primary-btn {
  width: 520rpx;
  height: 96rpx;
  margin-top: 30rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 34rpx;
  font-weight: 900;
  background: linear-gradient(180deg, #ffcf5d, #ff6e91);
  text-shadow: 0 3rpx 5rpx rgba(92, 44, 80, .35);
  box-shadow: 0 11rpx 0 #c64f72, inset 0 4rpx 0 rgba(255, 255, 255, .35);
}

.primary-btn.small {
  width: 360rpx;
  height: 82rpx;
  margin-top: 28rpx;
  font-size: 30rpx;
}

.plain-btn {
  width: 320rpx;
  height: 72rpx;
  margin-top: 18rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #526273;
  font-size: 26rpx;
  font-weight: 900;
  background: rgba(255, 255, 255, .62);
}

.title-actions {
  display: flex;
  gap: 22rpx;
  margin-top: 22rpx;
}

.title-actions button {
  width: 180rpx;
  height: 64rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #45616f;
  font-size: 24rpx;
  font-weight: 900;
  background: rgba(255, 255, 255, .58);
}

.soft-screen {
  background: rgba(48, 61, 120, .35);
  backdrop-filter: blur(8rpx);
}

.modal,
.parent-modal,
.rest-panel {
  width: 640rpx;
  max-width: calc(100vw - 64rpx);
  border-radius: 28rpx;
  padding: 36rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, .9);
  box-shadow: 0 20rpx 54rpx rgba(58, 68, 120, .24);
}

.modal-title {
  color: #354660;
  font-size: 42rpx;
  font-weight: 900;
}

.modal-copy {
  margin-top: 18rpx;
  color: #5e7082;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
}

.guide-list {
  width: 100%;
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.guide-list text {
  min-height: 58rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  color: #4b6072;
  font-size: 26rpx;
  font-weight: 800;
  background: #eef8ff;
}

.big-score {
  margin-top: 14rpx;
  color: #ff9b4a;
  font-size: 84rpx;
  font-weight: 900;
}

.result-grid {
  width: 100%;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 14rpx;
}

.result-grid view {
  height: 112rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #eef8ff;
}

.result-grid text:first-child {
  color: #354660;
  font-size: 32rpx;
  font-weight: 900;
}

.result-grid text:last-child {
  color: #738294;
  font-size: 22rpx;
  font-weight: 800;
}

.rest-screen {
  background: linear-gradient(180deg, #9be7ff, #dbf3ff 56%, #fff0b8);
}

.rest-orbit {
  position: absolute;
  width: 480rpx;
  height: 480rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, .68), rgba(255, 255, 255, 0) 68%);
}

.rest-panel {
  position: relative;
}

.rest-emoji {
  font-size: 84rpx;
}

.rest-title {
  margin-top: 8rpx;
  color: #354660;
  font-size: 42rpx;
  font-weight: 900;
}

.rest-copy,
.rest-tip {
  margin-top: 14rpx;
  color: #5d7182;
  font-size: 26rpx;
  line-height: 1.5;
  font-weight: 800;
  text-align: center;
}

.rest-count {
  margin-top: 22rpx;
  color: #ff7a6d;
  font-size: 64rpx;
  font-weight: 900;
}

.rest-progress {
  width: 100%;
  height: 26rpx;
  margin-top: 18rpx;
  border-radius: 13rpx;
  overflow: hidden;
  background: #d9edf7;
}

.rest-progress view {
  height: 100%;
  border-radius: 13rpx;
  background: linear-gradient(90deg, #84d87c, #ffd966);
}

.parent-screen {
  background: rgba(31, 43, 90, .42);
  backdrop-filter: blur(8rpx);
}

.answer-input {
  width: 260rpx;
  height: 76rpx;
  margin-top: 22rpx;
  border-radius: 18rpx;
  text-align: center;
  color: #344559;
  font-size: 30rpx;
  font-weight: 900;
  background: #eef8ff;
}

.setting-row {
  width: 100%;
  height: 74rpx;
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #4d6072;
  font-size: 25rpx;
  font-weight: 900;
}

.setting-row view {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.setting-row button {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 30rpx;
  font-weight: 900;
  background: #6fb7ff;
}
